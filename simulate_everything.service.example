[Unit]
Description=simulate_everything web server
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/path/to/simulate_everything

# Rebuild frontend + Rust binary on every (re)start
ExecStartPre=/bin/bash -lc "cd frontend && bun install && bun run vite build"
ExecStartPre=/bin/bash -lc "cargo build --release --bin simulate_everything"

ExecStart=/path/to/simulate_everything/target/release/simulate_everything

Environment=SIMEV_STATIC_DIR=/path/to/simulate_everything/frontend/dist
Environment=SIMEV_BIND_ADDR=0.0.0.0
Environment=SIMEV_PORT=3333
Environment=RUST_LOG=info

Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
